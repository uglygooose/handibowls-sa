# Template for local RLS integration tests. Copy to .env.test and fill with
# the output of `npx supabase status` while the local stack is running.
#
#   cp .env.test.example .env.test
#   npx supabase status         # copy Publishable + Secret key values
#
# The values change between Supabase CLI versions; don't hardcode. The final
# file is gitignored (stock keys are flagged by GitHub push protection even
# though they're well-known defaults).

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
