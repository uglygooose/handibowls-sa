# HandiBowls environment variables.
# Copy to .env.local and fill in per environment (never commit .env.local).

# Supabase (dev project: handibowls-dev; prod: handibowls-prod)
# Region: af-south-1 preferred, eu-west-1 fallback if unavailable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=HandiBowls

# Email (Resend — Phase 11)
# Source: Resend dashboard → API keys. Treat as a secret; rotate on
# leak. Server-only — never expose via NEXT_PUBLIC_*.
RESEND_API_KEY=

# Mandatory sender identity for every outbound Resend send. Must be
# a verified sender on the Resend account. RFC 5322 mailbox format
# with optional display name, e.g.
#   HandiBowls <no-reply@handibowls.co.za>
# Single global value for v1 — per-club overrides deferred per the
# Phase 11 prep decisions.
RESEND_FROM="HandiBowls <no-reply@handibowls.co.za>"

# HMAC secret used to sign POPIA unsubscribe links embedded in every
# outbound email. Generate locally with:
#   openssl rand -hex 32
# Rotating this invalidates any in-flight unsubscribe links — only
# rotate on confirmed compromise. Server-only.
EMAIL_UNSUBSCRIBE_SIGNING_SECRET=

# Resend webhook signing secret. Source: Resend dashboard →
# Webhooks → (target endpoint) → Signing secret. The
# /api/email/webhook route (Phase 11 / 11-2) verifies every incoming
# event signature against this value before mutating
# message_recipients.email_status. Server-only.
RESEND_WEBHOOK_SECRET=
